# not all namespace here are actually used here:
@prefix pico: <https://personsincontext.org/model#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix pnv:  <https://w3id.org/pnv#> .
@prefix schema:  <http://schema.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> . 
@prefix bag: <http://bag.basisregistraties.overheid.nl/def/bag#> .   # But the incomplete (and incorrect ?) 'labs' LD enviroment for the BAG (https://data.labs.kadaster.nl/bag/lv/) as LD uses https://
@prefix geo:   <http://www.opengis.net/ont/geosparql#>.
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix ldto: <https://data.razu.nl/def/ldto/> .
@prefix razu:   <https://data.example.org/id/> .             
@prefix po: <https://data.razu.nl/id/persoonsvermelding/> . # Thesaurus for person observations (pico)
@prefix pn: <https://data.razu.nl/id/persoonsnaam/> .       # Thesaurus for person names
@prefix dct: <http://purl.org/dc/terms/> .
@prefix premis: <http://www.loc.gov/premis/rdf/v3/> .


razu:nl-wbdrazu-g0352-403-1 # Toplevel 'archive', uri gemeentecode creator(see actor thesaurus) - {toegang} - {just a unique number} 
    a ldto:Informatieobject ;
    dct:hasFormat <https://g0352.opslag.razu.nl/nl-wbdrazu/g0352/403/000/000/nl-wbdrazu-g0352-403-1.meta.json> ; #dubbelcheck
    ldto:naam "Bouwvergunningen Wijk bij Duurstede {van}-{tot}" ;
    ldto:omschrijving "Gedigitaliseerde bouwvergunningen Rhenen {van}-{tot}." ;   # Useful to have an 'omschrijving' (?) but this example does not add much. # WB: See 'Inleiding' in the regular 'toegang' for an example of what I think we should include here: https://www.razu.nl/collectie/online-zoeken-in-archieven/?mivast=74&mizig=210&miadt=74&miview=inv2&milang=nl&mizk_alle=bouwvergunningen&micode=256#inv3t1
    ldto:identificatie [ 
        a ldto:IdentificatieGegevens ;
        ldto:identificatieBron "Toegangen collectiebeheersysteem RAZU" ;
        ldto:identificatieKenmerk "403"
    ] ;
    # add dekkingintijd
    ldto:archiefvormer  <https://data.razu.nl/id/actor/54c9a2e607988deae23c920dae4f43e4>; # Gem. Wijk bij Duurstede
    ldto:aggregatieniveau <https://data.razu.nl/id/aggregatieniveau/62d05f1b8d586edb7da7f257be926705> ; # "Archief"
    ldto:dekkingInTijd [
        a ldto:DekkingInTijdGegevens ;
        ldto:dekkingInTijdType <https://data.razu.nl/id/dekkingintijdtype/70a06aa707497017b24a599d24a4f9c9>;   # tijdbestek: geeft generiek aan welke periode documenten van zijn
        ldto:dekkingInTijdBeginDatum "1955"^^xsd:gYear ; # Only a startdate, a gYear since we that is what we have in the database.
    ] .

# are we creating an inbetween level? any reason too?

# A 'dossier', the record above:
razu:nl-wbdrazu-g0352-403-2    #
    a ldto:Informatieobject ;
    dct:hasFormat <https://g0352.opslag.razu.nl/nl-wbdrazu/g0352/403/000/000/nl-wbdrazu-g0352-403-2.meta.json> ;
    ldto:isOnderdeelVan razu:nl-wbdrazu-g0352-403-1 ; 
    ldto:naam "Bouwvergunning - Oprichten houten schuur voor berging landbouwwerktuigen"  ; # Always 'bouwvergunning', here we add {BOUWWERK} to create a more meaningful name.
    ldto:omschrijving "Bouwvergunning - Oprichten houten schuur voor berging landbouwwerktuigen. Caspargauw 8 te Cothen" ; # Kind of a summary, a combination of fields from the export (object, adres en opmerkingen, opmerkingen intern).

    ldto:identificatie [ 
        a ldto:IdentificatieGegevens ;
        ldto:identificatieBron "Gemeente Wijk bij Duurstede" ; # We should mention the system or provide more context, if possible. The source as a system, not an organization. Might go for URIs?
        ldto:identificatieKenmerk "1"  #  Do we have such a thing here, what field is it in the metadata?
    ] , [ 
        a ldto:IdentificatieGegevens ;
        ldto:identificatieBron "RAZU, inventarisnummer toegang 403" ;
        ldto:identificatieKenmerk "{INVNUMMER}"  # Or is it in {NUMMER+CODE} changed in newer export to INVNUMMER
    ] ;

    # Using trefwoorden in a way previously suggested does not seem to be worthwile here (too much low semantic value words)
    # ldto:trefwoord "Oprichten houten schuur voor berging landbouwwerktuigen" ;  

    ldto:aggregatieniveau <https://data.razu.nl/id/aggregatieniveau/f1a7b0e450eb0d62469cf223e5727b04> ; # Dossier 
    ldto:classificatie <https://data.razu.nl/id/soort/83f5430a921350f53972970595d2790c>  ; # "Bouwdossier" 
    
    # For this very record, we don't have any betrokkene information in the export:
    # This gave no results: sqlite3 maisexp.sqlite3 "SELECT * FROM bd JOIN piv ON bd.BD_ID = piv.BD_ID " | grep 1036572
    # Is it correct this info is not in the export?
    # ldto:betrokkene [ 
    #     a ldto:BetrokkeneGegevens ;
    #     ldto:betrokkeneTypeRelatie <https://data.razu.nl/id/betrokkenheid/80535b4e36061f628427ba168cc4bd5c> ; # "Aanvrager"
    #     ldto:betrokkeneActor po:po1 
    # ] ;
    # Same for sqlite3 maisexp.sqlite3 "SELECT * FROM bd JOIN rpiv ON bd.BD_ID = rpiv.BD_ID " | grep 1036572
    #ldto:betrokkene [
    #    a ldto:BetrokkeneGegevens ;
    #    ldto:betrokkeneTypeRelatie <https://data.razu.nl/id/betrokkenheid/4bb5da084da7cbef67d5f21bcb933af7> ; # "Architect" (need to add "Aannemer" too)
    #    ldto:betrokkeneActor po:po2 
    #] ;

    # We register the location separate from the building itself, since that fits mdto/ldto and the  'dekkingInRuimte'-predicates best.
    ldto:dekkingInRuimte [         # Should there always be just one? It might consists of multiple 'percelen' or addresses 
        a ldto:Locatie, bag:_AdresseerbaarObject ;  # or should / can we be more specific and use bag:Verblijfsobject but is that always correct? Not sure.
                                                    # "Een Adresseerbaar object is een (abstract) object waaraan adressen kunnen worden toegekend"        
        # The source metadata usually does not explicitly mention a bag:+AdresseerbaarObject (or Verblijfsobject). 
        
        # When it does, we'll addd the relevant bag:identificatie and owl:sameAs URI:
        #bag:identificatie  "0321010000005558" ;
        #owl:sameAs <http://bag.basisregistraties.overheid.nl/bag/id/verblijfsobject/0321010000005558>  ;

        # Each ldto:Locatie SHOULD - in this context have at least one 'address'. Since we usually will not know for sure if it is the bag-hoofdadres or bag-nevenadres, we use the generic schema:address relation
        # We might use two (multiple) addresses is we have a current address (which is in the BAG) and a historic address (which is not in the BAG).
        # Only current addresses have a  bag-identifier and owl:sameAs URI. Historical addresses have an rds:comment "Historisch adres, niet in huidige BAG"@nl .


        schema:address [        
            a schema:PostalAddress,     # always use this, since it is the most generic
                bag:Nummeraanduiding ;  # only use this when we have any "nummer"-aanduiding
            rdfs:label "Caspargauw 8, 3945PH Cothen" ;    # only required field here, we get it from the source metadata, add postcode, see following query
            # sqlite3 bag.sqlite "select n.postcode from Nummeraanduidingen n JOIN OpenbareRuimte o ON n.ligtAan = o.bagID JOIN WPL w ON n.ligtIn = w.identificatie WHERE n.huisnummer=8 AND n.huisletter IS NULL AND n.huisnummertoevoeging IS NULL AND o.naam='Caspargauw' AND w.naam='Cothen'"
            bag:huisnummer 8 ; # integer indeed!
            # If available, add the huisletter and huisnummertoevoeging:
            # bag:huisletter "A" ; # mind that BAG uses both upper and lower case: we normalize to uppercase only!
            # bag:huisnummerToevoeging # is this like 'bis'?

            bag:postcode "2524AB" ;  # without space in between; see previous query
            bag:identificatie "0321200000005558" ;  # sqlite3 bag.sqlite "select n.bagID from Nummeraanduidingen n JOIN OpenbareRuimte o ON n.ligtAan = o.bagID JOIN WPL w ON n.ligtIn = w.identificatie WHERE n.huisnummer=8 AND n.huisletter IS NULL AND n.huisnummertoevoeging IS NULL AND o.naam='Caspargauw' AND w.naam='Cothen'"
            owl:sameAs <http://bag.basisregistraties.overheid.nl/bag/id/nummeraanduiding/0321200000005558> ;
            bag:ligtAan [
                a bag:OpenbareRuimte ; # always, also when we can't find the OpenbareRuimte in the BAG
                bag:naam "Caspargauw" ; # only required field here, we get it from the source metadata
                bag:identificatie "0352300000000247" ; # sqlite3 bag.sqlite "select o.bagID from OpenbareRuimte o JOIN WPL w ON o.ligtIn = w.identificatie WHERE o.naam='Caspargauw' AND w.naam='Cothen'"
                owl:sameAs <http://bag.basisregistraties.overheid.nl/bag/id/openbare-ruimte/{bag:identicatie}> ;
            ] ;
            # Official bag data shows that ligtIn is used a a property of OpenbareRuimte, not of Nummeraanduiding. However, it is allowed to use it on Nummeraanduiding as well.
            # Less nesting improves the readability of the data. 

            bag:ligtIn [  # bag type, URI & identicatie are now in locaties thesaurus, so simply link to that
                a bag:Woonplaats ; # likely, all places are in the bag?
                bag:identificatie "1304"; # sqlite3 bag.sqlite "select w.identificatie from OpenbareRuimte o JOIN WPL w ON o.ligtIn = w.identificatie WHERE o.naam='Caspargauw' AND w.naam='Cothen'"
                bag:naam "Cothen" ;
                owl:sameAs <http://bag.basisregistraties.overheid.nl/bag/id/woonplaats/{bag:identificatie}>
            ] ;

            # When the metadata provides a bag:Pand identification, we'll include like it is done here.
            # bag:maaktDeelUitVan [
            #     a bag:Pand; 
            #     bag:identificatie "0321100000015890";
            #     owl:sameAs <http://bag.basisregistraties.overheid.nl/bag/id/pand/0321100000015890>
            # ]
        ] ;

        # The location should always have geolocation, based on either the address (using geonames?, or the 'percelen' data (see below):
        geo:hasGeometry [ 
            a geo:Geometry ;
            rdfs:label "Representatief punt" ;
            geo:asWKT "POINT({longitude} {latitude})"^^geo:wktLiteral ;  #sqlite3 bag.sqlite "select n.longitude, n.latitude from Nummeraanduidingen n JOIN OpenbareRuimte o ON n.ligtAan = o.bagID JOIN WPL w ON n.ligtIn = w.identificatie WHERE n.huisnummer=8 AND n.huisletter IS NULL AND n.huisnummertoevoeging IS NULL AND o.naam='Caspargauw' AND w.naam='Cothen'"
            # if we have a perceel, we might use that too
            geo:crs <http://www.opengis.net/def/crs/OGC/1.3/CRS84> 
        ] ;

        # When we have 'percelen' (parcels) metadata we add them using RAZU URIs. The URI's follow a very structured pattern.
        geo:sfWithin <https://data.razu.nl/id/perceel/ctn00/c/7> # geo:sfWithin indicates the location is within the cadastral parcel #LOWERCASE
        # see the file kadastrale-gemeentecodes.tsv
    ] ;
    ldto:dekkingInTijd [
        a ldto:DekkingInTijdGegevens ;
        ldto:dekkingInTijdType <https://data.razu.nl/id/dekkingintijdtype/70a06aa707497017b24a599d24a4f9c9>;   # tijdbestek: geeft generiek aan welke periode documenten van zijn
        ldto:dekkingInTijdBeginDatum "1955"^^xsd:gYear ; # Only a startdate, a gYear since we that is what we have in the database.
    ] .

