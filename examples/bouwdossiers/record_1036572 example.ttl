# './403 - Cothen tot 1996/403-325/403-325_3-OVERIGE-DOCUMENTEN.pdf'
# './403 - Cothen tot 1996/403-325/403-325_2-TEKENINGEN.pdf'


# can be found using  find . -type f -name "*OVERIGE-DOCUMENTEN.pdf" -exec pdfgrep -Hi "Geen documenten" {} \;  (I'll be putting the list in the bag)
