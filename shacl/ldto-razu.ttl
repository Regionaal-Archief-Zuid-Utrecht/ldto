@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sh:       <http://www.w3.org/ns/shacl#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:      <http://www.w3.org/2002/07/owl#> .
@prefix ldto:     <https://data.razu.nl/def/ldto/> .
@prefix ldto_sh:  <https://data.razu.nl/def/ldto-shacl/> .
@prefix ldto_esh: <https://data.razu.nl/def/ldto-extended-shacl/> .
@prefix skos:     <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms:  <http://purl.org/dc/terms/> .
@prefix premis:   <http://www.loc.gov/premis/rdf/v3/> .
@prefix schema:   <http://schema.org/> .
@prefix bag: <http://bag.basisregistraties.overheid.nl/def/bag#> .   # But the incomplete (and incorrect ?) 'labs' LD enviroment for the BAG (https://data.labs.kadaster.nl/bag/lv/) as LD uses https://
@prefix geo:   <http://www.opengis.net/ont/geosparql#>.

ldto_sh:razu 
    a owl:Ontology ;
    owl:imports ldto_sh:plus ;
    rdfs:label "LDTO plus SHACL shapes - with refs to RAZU terms" ;
    dcterms:creator <https://data.razu.nl/id/actor/2bdb658a032a405d71c19159bd2bbb3a> ;
    rdfs:comment "Nadere verfijning van de core shapes voor het RAZU toepassingsprofiel. Bevat verwijzingen naar termen uit thesauri van RAZU." .

###
# Enrichments to 'core':

ldto_sh:InformatieobjectShape
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Voor aggregatieniveau 'archiefstuk' moeten er precies 2 ldto:beperkingGebruik zijn." ;
        sh:select """
            SELECT ?this
            WHERE {
              ?this a <https://data.razu.nl/def/ldto/Informatieobject> ;
                    <https://data.razu.nl/def/ldto/aggregatieniveau> <https://data.razu.nl/id/aggregatieniveau/96f7399fb1c5d3b7d2acdc48dac3d71e> .
              OPTIONAL {
                ?this <https://data.razu.nl/def/ldto/beperkingGebruik> ?bg .
              }
            }
            GROUP BY ?this
            HAVING (COUNT(?bg) != 2)
        """ ;
    ] .

###
# Enrichments to 'plus'

ldto_sh:InformatieobjectShape
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "ldto:dekkingInRuimte kan verplicht zijn, afhankelijk van ldto:classificatie." ;
        sh:select """
            SELECT ?this
            WHERE {
              ?this <https://data.razu.nl/def/ldto/classificatie> ?c .
              FILTER (?c IN (
                <https://data.razu.nl/id/soort/e7f8935f15730273e0b9ab9a0f74b2f8> , # krant / newspaper
                <https://data.razu.nl/id/soort/83f5430a921350f53972970595d2790c>  # bouwdossier
              ))
              FILTER NOT EXISTS { ?this <https://data.razu.nl/def/ldto/dekkingInRuimte> ?dr . }
            }
        """ ;
    ] ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "ldto:isOnderdeelVan is verplicht, behalve als ldto:aggregatieniveau 'archief' is" ;
        sh:select """
            SELECT ?this
            WHERE {
                FILTER NOT EXISTS {
                    ?this <https://data.razu.nl/def/ldto/aggregatieniveau> <https://data.razu.nl/id/aggregatieniveau/62d05f1b8d586edb7da7f257be926705> .
                }
                FILTER NOT EXISTS {
                    ?this <https://data.razu.nl/def/ldto/isOnderdeelVan> ?parent .
                }
            }
        """ ;
    ] ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "schema:mainEntity kan verplicht zijn, afhankelijk van ldto:classificatie.." ;
        sh:select """
            SELECT ?this
            WHERE {
              ?this <https://data.razu.nl/def/ldto/classificatie> ?c .
              FILTER (?c IN (
                <https://data.razu.nl/id/soort/30d2cbfabc5d7cf795d3ddb00b1e8260>,
                <https://data.razu.nl/id/soort/e7f8935f15730273e0b9ab9a0f74b2f8>
              ))
              FILTER NOT EXISTS { ?this <http://schema.org/mainEntity> ?me . }
            }
        """ ;
    ] .

ldto_sh:BestandShape
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "De resource waar ldto:URLBestand naar verwijst moet een premis:originalName met stringwaarde hebben." ;
        sh:select """
            SELECT ?this
            WHERE {
              ?this a <https://data.razu.nl/def/ldto/Bestand> ;
                    <https://data.razu.nl/def/ldto/URLBestand> ?file .

              FILTER NOT EXISTS {
                ?file <http://www.loc.gov/premis/rdf/v3/originalName> ?name .
                FILTER ( isLiteral(?name) )
              }
            }
        """ ;
    ] .


ldto_sh:BouwdossierShape 
    a sh:NodeShape ;
    sh:target [
        a sh:SPARQLTarget ;
        sh:select """
            SELECT ?this
            WHERE {
                ?this a <https://data.razu.nl/def/ldto/Informatieobject> ;
                      <https://data.razu.nl/def/ldto/aggregatieniveau> <https://data.razu.nl/id/aggregatieniveau/f1a7b0e450eb0d62469cf223e5727b04> ;
                      <https://data.razu.nl/def/ldto/classificatie> <https://data.razu.nl/id/soort/83f5430a921350f53972970595d2790c> .
            }
            """ ;
    ] ;
    sh:property [
        sh:path ldto:dekkingInRuimte ;
        sh:minCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:node [
            a sh:NodeShape ;
            sh:and (
                [ sh:class ldto:Locatie ]
                [ sh:class bag:_AdresseerbaarObject ]
            ) ;
            sh:property [
                sh:path schema:address ;
                rdfs:comment "Adres moet in ieder geval een plaats (ligtIn) en straat (ligtAan) hebben." ;
                sh:minCount 1 ;
                sh:nodeKind sh:BlankNodeOrIRI ;
                sh:node [
                    a sh:NodeShape ;
                    sh:and (
                        [ sh:class schema:PostalAddress ]
                        [ sh:class bag:Nummeraanduiding ]
                    ) ;
                    sh:property [
                        sh:path rdfs:label ;
                        sh:minCount 1 ;
                        rdfs:comment "Bijvoorbeeld 'Caspargauw 8, 3945PH Cothen'" ;
                    ] ;
                    sh:property [
                        sh:path bag:huisnummer ;
                        sh:datatype xsd:integer ;
                        sh:minCount 0 ;
                        sh:maxCount 1 ;
                    ] ;
                    sh:property [
                        sh:path bag:huisletter ;
                        sh:datatype xsd:string ;
                        sh:minCount 0 ;
                        sh:maxCount 1 ;
                        sh:pattern "^[A-Z]$" ;
                        sh:message "Huisletter moet een hoofdletter zijn" ;
                    ] ;
                    sh:property [
                        sh:path bag:huisnummerToevoeging ;
                        sh:datatype xsd:string ;
                        sh:minCount 0 ;
                        sh:maxCount 1 ;
                    ] ;
                        sh:property [
                            sh:path bag:postcode ;
                            sh:datatype xsd:string ;
                            sh:minCount 0 ;
                            sh:maxCount 1 ;
                            sh:pattern "^[1-9][0-9]{3}[A-Z]{2}$" ;
                            sh:message "Postcode moet voldoen aan het formaat 1234AB" ;
                        ] ;
                    sh:property [
                        sh:path bag:identificatie ;
                        sh:datatype xsd:string ;
                        sh:minCount 0 ;
                        sh:maxCount 1 ;
                        sh:pattern "\\S" ;
                    ] ;
                    sh:property [
                        sh:path owl:sameAs ;
                        sh:nodeKind sh:IRI ;
                        sh:minCount 0 ;
                        sh:maxCount 1 ;
                    ] ;
                    sh:property [
                        sh:path bag:ligtAan ;
                        rdfs:comment "Verplichte eigenschap die de straat waarop het adres ligt linkt." ;
                        sh:minCount 1 ;
                        sh:maxCount 1 ;
                        sh:nodeKind sh:BlankNodeOrIRI ;
                        sh:node [
                            a sh:NodeShape ;
                            sh:class bag:OpenbareRuimte ;
                            sh:property [
                                sh:path bag:naam ;
                                sh:datatype xsd:string ;
                                sh:minCount 1 ;
                                sh:maxCount 1 ;
                                sh:pattern "\\S" ;
                            ] ;
                            sh:property [
                                sh:path bag:identificatie ;
                                sh:datatype xsd:string ;
                                sh:minCount 0 ;
                                sh:maxCount 1 ;
                                sh:pattern "\\S" ;
                            ] ;
                            sh:property [
                                sh:path owl:sameAs ;
                                sh:nodeKind sh:IRI ;
                                sh:minCount 0 ;
                                sh:maxCount 1 ;
                            ] ;
                            sh:sparql [
                                a sh:SPARQLConstraint ;
                                sh:message "Als bag:identificatie is ingevuld, moet er ook een owl:sameAs zijn." ;
                                sh:select """
                                    SELECT ?this
                                    WHERE {
                                        ?this <http://bag.basisregistraties.overheid.nl/def/bag#identificatie> ?id .
                                        FILTER NOT EXISTS {
                                            ?this <http://www.w3.org/2002/07/owl#sameAs> ?same .
                                            FILTER (isIRI(?same))
                                        }
                                    }
                                """ ;
                            ] ;
                            sh:sparql [
                                a sh:SPARQLConstraint ;
                                sh:message "owl:sameAs moet gelijk zijn aan http://bag.basisregistraties.overheid.nl/bag/id/openbare-ruimte/{bag:identificatie}." ;
                                sh:select """
                                    SELECT ?this
                                    WHERE {
                                        ?this <http://bag.basisregistraties.overheid.nl/def/bag#identificatie> ?id ;
                                              <http://www.w3.org/2002/07/owl#sameAs> ?same .

                                        FILTER (isIRI(?same))

                                        BIND(IRI(CONCAT("http://bag.basisregistraties.overheid.nl/bag/id/openbare-ruimte/", STR(?id))) AS ?expected)
                                        FILTER (?same != ?expected)
                                    }
                                """ ;
                            ]
                        ] ;
                    ] ;
                    sh:property [
                        sh:path bag:ligtIn ;
                        rdfs:comment "Verplichte eigenschap die de woonplaats waarop het adres ligt linkt." ;
                        sh:minCount 1 ;
                        sh:maxCount 1 ;
                        sh:nodeKind sh:BlankNodeOrIRI ;
                        sh:node [
                            a sh:NodeShape ;
                            sh:class bag:Woonplaats ;
                            sh:property [
                                sh:path bag:naam ;
                                sh:datatype xsd:string ;
                                sh:minCount 1 ;
                                sh:maxCount 1 ;
                                sh:pattern "\\S" ;
                            ] ;
                            sh:property [
                                sh:path bag:identificatie ;
                                sh:datatype xsd:string ;
                                sh:minCount 0 ;
                                sh:maxCount 1 ;
                                sh:pattern "\\S" ;
                            ] ;
                            sh:property [
                                sh:path owl:sameAs ;
                                sh:nodeKind sh:IRI ;
                                sh:minCount 0 ;
                                sh:maxCount 1 ;
                            ] ;
                            sh:sparql [
                                a sh:SPARQLConstraint ;
                                sh:message "Als bag:identificatie is ingevuld, moet er ook een owl:sameAs zijn." ;
                                sh:select """
                                    SELECT ?this
                                    WHERE {
                                        ?this <http://bag.basisregistraties.overheid.nl/def/bag#identificatie> ?id .
                                        FILTER NOT EXISTS {
                                            ?this <http://www.w3.org/2002/07/owl#sameAs> ?same .
                                            FILTER (isIRI(?same))
                                        }
                                    }
                                """ ;
                            ] ;
                            sh:sparql [
                                a sh:SPARQLConstraint ;
                                sh:message "owl:sameAs moet gelijk zijn aan http://bag.basisregistraties.overheid.nl/bag/id/woonplaats/{bag:identificatie}." ;
                                sh:select """
                                    SELECT ?this
                                    WHERE {
                                        ?this <http://bag.basisregistraties.overheid.nl/def/bag#identificatie> ?id ;
                                              <http://www.w3.org/2002/07/owl#sameAs> ?same .

                                        FILTER (isIRI(?same))

                                        BIND(IRI(CONCAT("http://bag.basisregistraties.overheid.nl/bag/id/woonplaats/", STR(?id))) AS ?expected)
                                        FILTER (?same != ?expected)
                                    }
                                """ ;
                            ]
                        ] ;
                    ] ;
                    sh:property [
                        sh:path bag:maaktDeelUitVan ;
                        rdfs:comment "Optionele eigenschap om een Pand in de BAG te linken." ;
                        sh:minCount 0 ;
                        sh:maxCount 1 ;
                        sh:nodeKind sh:BlankNodeOrIRI ;
                        sh:node [
                            a sh:NodeShape ;
                            sh:class bag:Pand ;
                            sh:property [
                                sh:path bag:identificatie ;
                                sh:datatype xsd:string ;
                                sh:minCount 1 ;
                                sh:maxCount 1 ;
                                sh:pattern "\\S" ;
                            ] ;
                            sh:property [
                                sh:path owl:sameAs ;
                                sh:nodeKind sh:IRI ;
                                sh:minCount 1 ;
                                sh:maxCount 1 ;
                            ] ;
                            sh:sparql [
                                a sh:SPARQLConstraint ;
                                sh:message "owl:sameAs moet gelijk zijn aan http://bag.basisregistraties.overheid.nl/bag/id/pand/{bag:identificatie}." ;
                                sh:select """
                                    SELECT ?this
                                    WHERE {
                                        ?this <http://bag.basisregistraties.overheid.nl/def/bag#identificatie> ?id ;
                                              <http://www.w3.org/2002/07/owl#sameAs> ?same .

                                        FILTER (isIRI(?same))

                                        BIND(IRI(CONCAT("http://bag.basisregistraties.overheid.nl/bag/id/pand/", STR(?id))) AS ?expected)
                                        FILTER (?same != ?expected)
                                    }
                                """ ;
                            ]
                        ] ;
                    ] ;
                    sh:sparql [
                        a sh:SPARQLConstraint ;
                        sh:message "Als bag:identificatie is ingevuld, moet er ook een owl:sameAs zijn." ;
                        sh:select """
                            SELECT ?this
                            WHERE {
                                ?this <http://bag.basisregistraties.overheid.nl/def/bag#identificatie> ?id .
                                FILTER NOT EXISTS {
                                    ?this <http://www.w3.org/2002/07/owl#sameAs> ?same .
                                    FILTER (isIRI(?same))
                                }
                            }
                        """ ;
                    ] ;
                    sh:sparql [
                        a sh:SPARQLConstraint ;
                        sh:message "owl:sameAs moet gelijk zijn aan http://bag.basisregistraties.overheid.nl/bag/id/nummeraanduiding/{bag:identificatie}." ;
                        sh:select """
                            SELECT ?this
                            WHERE {
                                ?this <http://bag.basisregistraties.overheid.nl/def/bag#identificatie> ?id ;
                                      <http://www.w3.org/2002/07/owl#sameAs> ?same .

                                FILTER (isIRI(?same))

                                BIND(IRI(CONCAT("http://bag.basisregistraties.overheid.nl/bag/id/nummeraanduiding/", STR(?id))) AS ?expected)
                                FILTER (?same != ?expected)
                            }
                        """ ;
                    ] ;
                    
                ] ;
            ] ;
            sh:property [
                sh:path geo:hasGeometry ;
                sh:minCount 1 ;
                sh:nodeKind sh:BlankNodeOrIRI ;
                sh:node [
                    a sh:NodeShape ;
                    sh:class geo:Geometry ;
                    sh:property [
                        sh:path rdfs:label ;
                        sh:minCount 1 ;
                        rdfs:comment "Bijvoorbeeld 'Representatief punt'" ;
                    ] ;
                    sh:property [
                        sh:path geo:asWKT ;
                        sh:minCount 1 ;
                    ] ;
                    sh:property [
                        sh:path geo:crs ;
                        sh:minCount 1 ;
                        sh:hasValue <http://www.opengis.net/def/crs/OGC/1.3/CRS84> ;
                    ]
                ] ;
            ] ;
            sh:property [
                rdfs:comment "Als we metadata over 'percelen' hebben, voegen we die toe met RAZU-URI's. Die URI's volgen een vast patroon, bijvoorbeeld <https://data.razu.nl/id/perceel/ctn00/c/7>" ;
                sh:path geo:sfWithin ;
                sh:minCount 0 ;
                sh:nodeKind sh:IRI ;
            ]
        ] ;
    ] .